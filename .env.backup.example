# Backup & Cloud Storage Environment Variables
# Tambahkan variabel ini ke .env Anda

# ============================================================
# AWS S3 / Cloud Storage Configuration
# ============================================================

# Untuk AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=peminjaman-buku-backups
AWS_USE_PATH_STYLE_ENDPOINT=false

# Untuk DigitalOcean Spaces (uncomment jika menggunakan)
# AWS_ENDPOINT=https://sgp1.digitaloceanspaces.com

# Untuk MinIO Self-Hosted (uncomment jika menggunakan)
# AWS_ENDPOINT=https://your-minio-server.com
# AWS_USE_PATH_STYLE_ENDPOINT=true

# ============================================================
# Backup Configuration
# ============================================================

# Disk untuk menyimpan backup (local atau s3)
BACKUP_DISK=s3

# Email untuk notifikasi backup
BACKUP_NOTIFICATION_EMAIL=admin@example.com

# Password untuk enkripsi backup archive (AES-256)
BACKUP_ARCHIVE_PASSWORD=your_very_secure_password_here_min_8_chars

# ============================================================
# Email / SMTP Configuration (untuk notifikasi backup)
# ============================================================

# Menggunakan Gmail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_not_regular_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=backup@example.com
MAIL_FROM_NAME="Peminjaman Buku Backups"

# Atau menggunakan Mailtrap (Testing)
# MAIL_HOST=live.smtp.mailtrap.io
# MAIL_PORT=587
# MAIL_USERNAME=your_mailtrap_username
# MAIL_PASSWORD=your_mailtrap_password

# ============================================================
# Scheduler Timezone
# ============================================================

# Timezone untuk scheduler backup
APP_TIMEZONE=Asia/Jakarta
